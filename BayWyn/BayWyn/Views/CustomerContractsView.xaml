<UserControl x:Class="BayWyn.Views.CustomerContractsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock Text="Customer Contracts" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <Label Content="Business Name"/>
            <TextBox Height="30" Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Content="Address"/>
            <TextBox Height="30" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Content="Phone Number"/>
            <TextBox Height="30" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Content="Email"/>
            <TextBox Height="30" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Content="Notes"/>
            <TextBox Height="30" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Button Content="Create Contract" Width="140" Height="35" Margin="0,0,10,0"
                        Command="{Binding AddContractCommand}"/>
                <Button Content="Update Contract" Width="140" Height="35"
                        Command="{Binding UpdateContractCommand}"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False"
                  ItemsSource="{Binding Contracts}"
                  SelectedItem="{Binding SelectedContract, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CustomerRecordNumber}" Width="60"/>
                <DataGridTextColumn Header="Business" Binding="{Binding BusinessName}" Width="150"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="110"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="150"/>
                <DataGridTextColumn Header="Monthly" Binding="{Binding MonthlyContractCost}" Width="80"/>
                <DataGridTextColumn Header="Run Cost" Binding="{Binding CourierRunCost}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
