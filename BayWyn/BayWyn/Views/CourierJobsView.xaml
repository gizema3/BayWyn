<UserControl x:Class="BayWyn.Views.CourierJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock Text="Courier Jobs" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <Label Content="Client Name"/>
            <TextBox Height="30" Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"/>

            <CheckBox Margin="5" Content="Is Contract Client" IsChecked="{Binding IsContractClient}"/>

            <Label Content="Delivery Date"/>
            <DatePicker SelectedDate="{Binding DeliveryDate}"/>

            <Label Content="Time Slot"/>
            <ComboBox Height="30" ItemsSource="{Binding TimeSlots}" SelectedItem="{Binding SelectedTimeSlot}"/>

            <Label Content="Courier"/>
            <ComboBox Height="30" ItemsSource="{Binding Couriers}" SelectedItem="{Binding SelectedCourier}"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Button Content="Create Job" Width="110" Height="35" Margin="0,0,10,0" Command="{Binding AddJobCommand}"/>
                <Button Content="Update Job" Width="110" Height="35" Margin="0,0,10,0" Command="{Binding UpdateJobCommand}"/>
                <Button Content="Cancel Job" Width="110" Height="35" Command="{Binding CancelJobCommand}"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding JobId}" Width="60"/>
                <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="140"/>
                <DataGridCheckBoxColumn Header="Contract" Binding="{Binding IsContractClient}" Width="80"/>
                <DataGridTextColumn Header="Date" Binding="{Binding DeliveryDate, StringFormat=d}" Width="110"/>
                <DataGridTextColumn Header="Time" Binding="{Binding DeliveryTime}" Width="80"/>
                <DataGridTextColumn Header="Courier" Binding="{Binding CourierName}" Width="100"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=£{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </UserControl>