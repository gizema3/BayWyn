<UserControl x:Class="BayWyn.Views.CourierJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="3" Margin="0,0,0,20">
            
        </Grid>
<!--Form input attributes-->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Job Details" Style="{StaticResource SectionTitleText}"/>
                <TextBlock Text="Create a new delivery or select an existing one."
                           Margin="0,6,0,0"
                           Style="{StaticResource BodyMutedText}"/>

                <StackPanel Margin="0,22,0,0">
                    <TextBlock Text="Client Name" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <CheckBox Margin="0,16,0,0" Content="Contract client" IsChecked="{Binding IsContractClient}"/>

                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Delivery Date" Style="{StaticResource LabelTextStyle}"/>
                    <DatePicker SelectedDate="{Binding DeliveryDate}"/>
                </StackPanel>

                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Time Slot" Style="{StaticResource LabelTextStyle}"/>
                    <ComboBox ItemsSource="{Binding TimeSlots}" SelectedItem="{Binding SelectedTimeSlot}"/>
                </StackPanel>

                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Courier" Style="{StaticResource LabelTextStyle}"/>
                    <ComboBox ItemsSource="{Binding Couriers}" SelectedItem="{Binding SelectedCourier}"/>
                </StackPanel>

                <StackPanel Margin="0,22,0,0">
                    <Button Content="Create Job" Style="{StaticResource PrimaryButton}" Command="{Binding AddJobCommand}"/>
                    <Button Content="Update Job" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" Command="{Binding UpdateJobCommand}"/>
                    <Button Content="Cancel Job" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" Command="{Binding CancelJobCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Scheduled Jobs" Style="{StaticResource SectionTitleText}"/>
                    
                </StackPanel>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Jobs}"
                          SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                    <DataGrid.Columns> <!--Data display-->
                        <DataGridTextColumn Header="ID" Binding="{Binding JobId}" Width="60"/>
                        <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="150"/>
                        <DataGridCheckBoxColumn Header="Contract" Binding="{Binding IsContractClient}" Width="85"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding DeliveryDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding DeliveryTime}" Width="80"/>
                        <DataGridTextColumn Header="Courier" Binding="{Binding CourierName}" Width="100"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=£{0:F2}}" Width="90"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>