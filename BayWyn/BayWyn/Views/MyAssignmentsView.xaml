<UserControl x:Class="BayWyn.Views.MyAssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="My Assignments" Style="{StaticResource SectionTitleText}" FontSize="24"/>
            
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <WrapPanel> <!--Delivery status update-->
                    <Button Content="Accept Assignment"
                            Width="180"
                            Margin="0,0,10,0"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AcceptCommand}"/>
                    <Button Content="Mark Delivered"
                            Width="180"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeliverCommand}"/>
                </WrapPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Assigned Jobs" Style="{StaticResource SectionTitleText}"/>
                        
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding MyJobs}"
                              SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                        <DataGrid.Columns> <!--Data display-->
                            <DataGridTextColumn Header="ID" Binding="{Binding JobId}" Width="70"/>
                            <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="180"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DeliveryDate, StringFormat=d}" Width="120"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding DeliveryTime}" Width="90"/>
                            <DataGridTextColumn Header="Courier" Binding="{Binding CourierName}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>