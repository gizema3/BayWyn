<Window x:Class="BayWyn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BayWyn.Views"
        xmlns:vm="clr-namespace:BayWyn.ViewModels"
        Title="BayWyn Couriers" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        
        <DataTemplate DataType="{x:Type vm:CustomerContractsViewModel}">
            <views:CustomerContractsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CourierJobsViewModel}">
            <views:CourierJobsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MyAssignmentsViewModel}">
            <views:MyAssignmentsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding WelcomeText}" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Customer Contracts" Width="160" Height="38" Margin="0,0,10,0"
                    Visibility="{Binding CanViewContracts, Converter={StaticResource BoolToVisibilityConverter}}"
                    Click="Contracts_Click"/>
            <Button Content="Courier Jobs" Width="160" Height="38" Margin="0,0,10,0"
                    Visibility="{Binding CanViewJobs, Converter={StaticResource BoolToVisibilityConverter}}"
                    Click="Jobs_Click"/>
            <Button Content="My Assignments" Width="160" Height="38" Margin="0,0,10,0"
                    Visibility="{Binding CanViewAssignments, Converter={StaticResource BoolToVisibilityConverter}}"
                    Click="Assignments_Click"/>
            <Button Content="Reports" Width="160" Height="38"
                    Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibilityConverter}}"
                    Click="Reports_Click"/>
        </StackPanel>

        <ContentControl Grid.Row="2" Content="{Binding CurrentView}"/>
    </Grid>
</Window>